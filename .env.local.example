# Database (used only if you run prisma/migrations from the panel)
DATABASE_URL=postgres://ribbler:ribbler@localhost:5433/ribbler_dev

# Better-Auth (local instance)
BETTER_AUTH_SECRET=replace-with-random-32-bytes
BETTER_AUTH_URL=http://localhost:3000

# Shared with core-module — JWT_SECRET MUST match core-module/.env exactly,
# the proxy mints HS256 tokens that core-module verifies with this same secret.
JWT_SECRET=dev-jwt-secret-replace-me-at-least-32-bytes-long
ENCRYPTION_KEY=dev-encryption-key-32-bytes-12345

# Where the Hono backend lives. The /api/proxy/[...path] route forwards to this.
CORE_MODULE_URL=http://localhost:8787
